{
  "files.exclude": {
    "**/.git": true,
    "**/node_modules": true,
    "**/LICENSE": true,
    "**/README.md": false
  },
  "editor.formatOnSave": true,

  "[java]": {
    "editor.defaultFormatter": "redhat.java"
  },

  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.organizeImports": "explicit"
  },
  "java.configuration.updateBuildConfiguration": "interactive"
}
